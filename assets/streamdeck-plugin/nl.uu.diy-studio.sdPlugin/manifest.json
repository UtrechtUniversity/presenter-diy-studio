		{
			"Icon": "assets/record",
			"Name": "Record-stop toggle",
			"Controllers": ["Keypad"],
			"States": [
				{
					"Image": "assets/record",
					"TitleAlignment": "bottom", 
          			"FontSize": "12"
				}
			],
			"Tooltip": "Start and stop the recording",
			"UUID": "nl.uu.diy-studio.record"
		},
		{
			"Icon": "assets/pp-rewind",
			"Name": "Back to first slide",
			"Controllers": ["Keypad"],
			"States": [
				{
					"Image": "assets/pp-rewind",
					"TitleAlignment": "bottom",
					"FontSize": 12
				}
			],
			"Tooltip": "Go back to the first slide of the presentation",
			"UUID": "nl.uu.diy-studio.pp-rewind"
		},
		{
			"Icon": "assets/pp-prev",
