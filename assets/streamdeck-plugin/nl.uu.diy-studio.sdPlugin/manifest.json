			"Controllers": ["Keypad"],
			"States": [
				{
					"Image": "assets/pp-prev",
					"TitleAlignment": "bottom", 
          			"FontSize": "12"
				}
			],
			"Tooltip": "Go back to the previous PowerPoint slide",
