		{
			"Icon": "assets/lang-en",
			"Name": "Language toggle",
			"Controllers": ["Keypad"],
			"States": [
				{
					"Image": "assets/lang-en",
					"TitleAlignment": "bottom", 
          			"FontSize": "12"
				}
			],
			"Tooltip": "Switch the language of the app between Dutch and English",
			"UUID": "nl.uu.diy-studio.lang"
